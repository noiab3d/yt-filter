{
  "name": "yt-filter",
  "version": "0.1.0",
  "description": "Extensão de browser que filtra a homepage de recomendações do YouTube (idade, duração, views, Shorts).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "dev:firefox": "web-ext run --source-dir dist/firefox --firefox-profile yt-filter-dev --profile-create-if-missing --keep-profile-changes",
    "lint:web-ext": "web-ext lint --source-dir dist/firefox",
    "test:selectors": "node tests/selector-check.js"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "playwright": "^1.61.1",
    "web-ext": "^8.3.0"
  }
}
