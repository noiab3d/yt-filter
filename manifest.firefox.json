{
  "manifest_version": 3,
  "name": "YT Filter",
  "version": "0.1.0",
  "description": "Filtra a homepage de recomendações do YouTube por idade, duração, views e Shorts.",
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-filter@david",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
