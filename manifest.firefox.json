{
  "manifest_version": 3,
  "name": "YT Filter",
  "version": "0.1.0",
  "description": "Filtra a homepage de recomendações do YouTube por idade, duração, views e Shorts.",
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-filter@david",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://www.youtube.com/*"
  ],
  "icons": {
    "16": "icons/x16.png",
    "32": "icons/x32.png",
    "48": "icons/x48.png",
    "128": "icons/x128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/x16.png",
      "32": "icons/x32.png"
    },
    "default_title": "YT Filter"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
